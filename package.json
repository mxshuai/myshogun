{
  "name": "my-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "build:lambda": "esbuild app/functions/publish.ts --bundle --platform=node --target=node20 --outfile=infra/dist/publish/index.js --format=esm --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/server.mjs",
    "start:local-prod": "powershell -ExecutionPolicy Bypass -File scripts/start-local-prod.ps1",
    "verify:local-admin": "powershell -ExecutionPolicy Bypass -File scripts/verify-local-admin.ps1",
    "preview:amplify": "node ./.amplify-hosting/compute/default/server.mjs",
    "typecheck": "react-router typegen && tsc",
    "verify:publish-flow": "tsx scripts/verify-publish-flow.ts",
    "deploy:data-plane": "powershell -ExecutionPolicy Bypass -File scripts/deploy-data-plane.ps1",
    "deploy:publish-lambda": "powershell -ExecutionPolicy Bypass -File scripts/deploy-publish-lambda.ps1"
  },
  "dependencies": {
    "@puckeditor/core": "^0.21.2",
    "@react-router/express": "^7.5.3",
    "@react-router/node": "^7.5.3",
    "@react-router/serve": "^7.5.3",
    "compression": "^1.8.1",
    "express": "^4.21.2",
    "morgan": "^1.10.1",
    "isbot": "^5",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router": "^7.5.3",
    "@aws-sdk/client-dynamodb": "^3.758.0",
    "@aws-sdk/client-scheduler": "^3.758.0",
    "@aws-sdk/client-secrets-manager": "^3.758.0",
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/lib-dynamodb": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "tsx": "^4.19.3",
    "@react-router/dev": "^7.5.3",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.3",
    "vite-plugin-react-router-amplify-hosting": "^0.7.0",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
