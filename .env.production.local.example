# Copy this file to .env.production.local before local production verification.
# Do not commit real secrets.

USE_AWS_DATA_LAYER=true
APP_AWS_REGION=ap-southeast-2
APP_TABLE_NAME=visbuild-shopify-app
PUBLISH_LAMBDA_ARN=arn:aws:lambda:ap-southeast-2:124074140777:function:visbuild-shopify-data-publish
SCHEDULER_ROLE_ARN=arn:aws:iam::124074140777:role/visbuild-shopify-data-SchedulerInvokeRole-REPLACE_ME
SHOPIFY_TOKEN_SECRET_PREFIX=visbuild-shopify/token

# Shopify Embedded App (Partners Public App)
SHOPIFY_API_KEY=your-partners-client-id
SHOPIFY_API_SECRET=your-partners-client-secret
SCOPES=read_content,write_content
SHOPIFY_APP_URL=https://master.d3w458ytk16hpm.amplifyapp.com

# 方案 C（seed:publish-test，可选）
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxx

# Optional:
# SHOP_CUSTOM_DOMAIN=your-custom-domain.com
# PORT=3000
# SEED_SKIP_INVOKE=1
